// Queue — FIFO data structure (ring buffer using int[])

func queue_new() -> int[] {
    []
}

func queue_enqueue(q: int[], val: int) {
    q.reverse()
    q.push(val)
    q.reverse()
}

func queue_dequeue(q: int[]) -> int {
    q.pop()
}

func queue_peek(q: int[]) -> int {
    q[0]
}

func queue_len(q: int[]) -> int {
    q.len()
}

func queue_is_empty(q: int[]) -> bool {
    q.is_empty()
}

func queue_clear(q: int[]) {
    q.clear()
}
